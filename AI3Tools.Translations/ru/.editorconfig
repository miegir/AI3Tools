[*]
# VSSPELL: Spell checker settings from ru.vsspell
vsspell_section_id = cb0ff450291a457bbc8c77fe0a4d0a4b
vsspell_spell_check_as_you_type = true
vsspell_include_in_project_spell_check = true
vsspell_code_analyzers_enabled = false
vsspell_detect_doubled_words = false
vsspell_ignore_words_with_digits = true
vsspell_ignore_words_in_all_uppercase = true
vsspell_ignore_words_in_mixed_case = true
vsspell_ignore_format_specifiers = true
vsspell_ignore_filenames_and_email_addresses = true
vsspell_ignore_xml_elements_in_text = true
vsspell_treat_underscore_as_separator = false
vsspell_ignore_mnemonics = true
vsspell_ignored_character_class = None
vsspell_additional_dictionary_folders_cb0ff450291a457bbc8c77fe0a4d0a4b = clear_inherited|..\dic
vsspell_dictionary_languages_cb0ff450291a457bbc8c77fe0a4d0a4b = en-US,ru-RU
vsspell_ignored_words_cb0ff450291a457bbc8c77fe0a4d0a4b = clear_inherited
vsspell_exclusion_expressions_cb0ff450291a457bbc8c77fe0a4d0a4b = clear_inherited(?@@PND@@/Options/).*//spell-ignore-line(?@@PND@@/Options/None)//spell-ignore:\w+\b(?@@PND@@/Options/None)\"(src|yax|path)\".*$(?@@PND@@/Options/None)\"trx\"\:(?@@PND@@ trx header)(?@@PND@@/Options/None)^\s*\"[^"]+\": \{$(?@@PND@@/Options/Multiline)\b(\w+)(?=\b.*//spell-ignore:(?i:\1)\b)(?@@PND@@/Options/None)\\n(?@@PND@@/Options/None)Голден Йокотё(?@@PND@@/Options/None)
vsspell_cad_import_code_analysis_dictionaries = true
vsspell_cad_treat_unrecognized_words_as_misspelled = true
vsspell_cad_treat_deprecated_terms_as_misspelled = true
vsspell_cad_treat_compound_terms_as_misspelled = true
vsspell_cad_treat_casing_exceptions_as_ignored_words = false
vsspell_cad_recognized_word_handling = IgnoreAllWords
vsspell_ignored_classifications_cb0ff450291a457bbc8c77fe0a4d0a4b = clear_inherited

[*.code.txt]
# VSSPELL: Ignored file pattern from ru.vsspell
vsspell_spell_check_as_you_type = false
vsspell_include_in_project_spell_check = false

